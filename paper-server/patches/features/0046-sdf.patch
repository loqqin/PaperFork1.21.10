diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index e4a5c54e0a702b8c822371d88654deda8113033a..d9ad60c7ade8f6cb72231e32cb3db4a3c27f64fc 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -3688,6 +3688,9 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
     protected void serverAiStep() {
     }
 
+    public static final it.unimi.dsi.fastutil.ints.Int2DoubleOpenHashMap boundingBoxInflateMap = new it.unimi.dsi.fastutil.ints.Int2DoubleOpenHashMap();
+    public static final it.unimi.dsi.fastutil.ints.Int2IntOpenHashMap maxEntityCollisionsMap = new it.unimi.dsi.fastutil.ints.Int2IntOpenHashMap();
+
     protected void pushEntities() {
         // Paper start - don't run getEntities if we're not going to use its result
         if (!this.isPushable()) {
@@ -3704,7 +3707,8 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
             return;
         }
         // Paper end - don't run getEntities if we're not going to use its result
-        List<Entity> pushableEntities = this.level().getPushableEntities(this, this.getBoundingBox());
+        final double v = boundingBoxInflateMap.get(getId());
+        List<Entity> pushableEntities = this.level().getPushableEntities(this, v == 0 ? this.getBoundingBox() : this.getBoundingBox().inflate(v));
         if (!pushableEntities.isEmpty()) {
             if (this.level() instanceof ServerLevel serverLevel) {
                 // Paper - don't run getEntities if we're not going to use its result; moved up
@@ -3724,9 +3728,14 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
             }
 
             // Paper start - Cap entity collisions
-            this.numCollisions = Math.max(0, this.numCollisions - this.level().paperConfig().collisions.maxEntityCollisions);
+            int maxEntityCollisions = this.level().paperConfig().collisions.maxEntityCollisions;
+            final int i = maxEntityCollisionsMap.get(getId());
+            if (i > 0) {
+                maxEntityCollisions = i;
+            }
+            this.numCollisions = Math.max(0, this.numCollisions - maxEntityCollisions);
             for (Entity entity1 : pushableEntities) {
-                if (this.numCollisions >= this.level().paperConfig().collisions.maxEntityCollisions) {
+                if (this.numCollisions >= maxEntityCollisions) {
                     break;
                 }
 
